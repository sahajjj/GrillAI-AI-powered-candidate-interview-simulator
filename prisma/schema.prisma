datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  avatar    String?
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  role           String
  type           String
  difficulty     String
  overallScore   Float
  communication  Float
  technicalDepth Float
  clarity        Float
  confidence     Float
  questions      String   // Serialized array of Q&A objects
  strengths      String   // Serialized array of strings
  improvements   String   // Serialized array of strings
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
